---
import Layout from '../layouts/Layout.astro';
import SportsCarousel from '../components/SportsCarousel.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
import { getActiveSlides, getMusic } from '../lib/data';

const slides = await getActiveSlides();
const music = await getMusic();
---

<Layout>
	<SportsCarousel slides={slides} />
	<MusicPlayer playlistEnabled={music.playlistEnabled} tracks={music.tracks} />
</Layout>
