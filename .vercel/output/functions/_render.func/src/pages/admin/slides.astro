---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Imágenes">
	<section class="admin-card">
		<h2>Imágenes por semana o día</h2>
		<p>Paso 1: elige el modo. Paso 2: selecciona el periodo. Paso 3: carga y ordena imágenes.</p>

		<div class="admin-steps">
			<span class="admin-step is-active" id="step-1">1. Modo</span>
			<span class="admin-step" id="step-2">2. Periodo</span>
			<span class="admin-step" id="step-3">3. Imágenes</span>
		</div>

		<div class="admin-grid">
			<div class="admin-field">
				<label for="view-mode">Modo de visualización</label>
				<select id="view-mode">
					<option value="week">Por semana</option>
					<option value="day">Por día</option>
				</select>
			</div>
		</div>
	</section>

	<section class="admin-card" id="period-card">
		<h3 id="period-title">Periodo activo</h3>
		<div class="admin-grid" id="week-fields">
			<div class="admin-field">
				<label for="week-select">Semana</label>
				<select id="week-select"></select>
			</div>
			<div class="admin-field">
				<label for="week-label">Etiqueta</label>
				<input id="week-label" placeholder="25 al 31 de Mayo" />
			</div>
			<div class="admin-field">
				<label for="week-start">Desde</label>
				<input id="week-start" type="date" />
			</div>
			<div class="admin-field">
				<label for="week-end">Hasta</label>
				<input id="week-end" type="date" />
			</div>
		</div>
		<div class="admin-grid hidden" id="day-fields">
			<div class="admin-field">
				<label for="day-select">Día</label>
				<select id="day-select"></select>
			</div>
			<div class="admin-field">
				<label for="day-label">Etiqueta</label>
				<input id="day-label" placeholder="Domingo 25" />
			</div>
			<div class="admin-field">
				<label for="day-date">Fecha</label>
				<input id="day-date" type="date" />
			</div>
		</div>
		<div class="admin-actions">
			<button class="admin-btn admin-btn--ghost" type="button" id="add-period-btn">Nuevo periodo</button>
		</div>
	</section>

	<section class="admin-card">
		<h3>Lista de imágenes</h3>
		<p class="admin-list__hint">Arrastra desde el icono ⋮⋮ para cambiar el orden. El número indica la posición en pantalla.</p>
		<div class="admin-list" id="slides-list"></div>

		<form class="admin-grid" id="upload-form" style="margin-top: 1rem">
			<div class="admin-field">
				<label for="slide-file">Subir imagen</label>
				<input id="slide-file" name="file" type="file" accept="image/*" />
			</div>
			<div class="admin-field">
				<label for="slide-alt">Descripción</label>
				<input id="slide-alt" placeholder="Ej. Fútbol Peruano" />
			</div>
			<div class="admin-actions">
				<button class="admin-btn" type="submit">Agregar imagen</button>
				<button class="admin-btn admin-btn--ghost" type="button" id="save-btn">Guardar cambios</button>
			</div>
		</form>
		<p class="admin-status hidden" id="slides-status"></p>
	</section>

	<script>
		import { bindSortableList, escapeHtml, updatePositionNumbers } from '../../lib/admin-ui';

		type Slide = { id: string; src: string; alt: string; order: number };
		type Week = { id: string; label: string; startDate: string; endDate: string; slides: Slide[] };
		type Day = { date: string; label: string; slides: Slide[] };
		type Schedule = {
			viewMode: 'week' | 'day';
			activeWeekId: string;
			activeDate: string;
			weeks: Week[];
			days: Day[];
		};

		let schedule: Schedule;
		let sortableReady = false;

		const viewMode = document.getElementById('view-mode') as HTMLSelectElement;
		const weekFields = document.getElementById('week-fields') as HTMLDivElement;
		const dayFields = document.getElementById('day-fields') as HTMLDivElement;
		const weekSelect = document.getElementById('week-select') as HTMLSelectElement;
		const daySelect = document.getElementById('day-select') as HTMLSelectElement;
		const slidesList = document.getElementById('slides-list') as HTMLDivElement;
		const status = document.getElementById('slides-status') as HTMLParagraphElement;

		function setStatus(message: string, type: 'success' | 'error' | '' = '') {
			status.classList.remove('hidden', 'is-success', 'is-error');
			status.textContent = message;
			if (type) status.classList.add(type === 'success' ? 'is-success' : 'is-error');
		}

		function currentSlides(): Slide[] {
			if (schedule.viewMode === 'week') {
				return schedule.weeks.find((week) => week.id === schedule.activeWeekId)?.slides ?? [];
			}
			return schedule.days.find((day) => day.date === schedule.activeDate)?.slides ?? [];
		}

		function syncSlidesFromDom() {
			const slides = currentSlides();
			slidesList.querySelectorAll('[data-sortable-item]').forEach((item, index) => {
				const id = item.getAttribute('data-id');
				const slide = slides.find((entry) => entry.id === id);
				if (!slide) return;
				slide.alt = (item.querySelector('[data-field="alt"]') as HTMLInputElement).value;
				slide.src = (item.querySelector('[data-field="src"]') as HTMLInputElement).value;
				slide.order = index + 1;
			});
		}

		function reorderSlides(orderedIds: string[]) {
			syncSlidesFromDom();
			const slides = currentSlides();
			const map = new Map(slides.map((slide) => [slide.id, slide]));
			slides.splice(0, slides.length, ...orderedIds.map((id, index) => {
				const slide = map.get(id);
				if (!slide) throw new Error('Slide missing');
				slide.order = index + 1;
				return slide;
			}));
			renderSlides();
		}

		function ensureSortable() {
			if (sortableReady) return;
			bindSortableList(slidesList, reorderSlides);
			sortableReady = true;
		}

		function renderSlides() {
			const slides = [...currentSlides()].sort((a, b) => a.order - b.order);

			if (!slides.length) {
				slidesList.innerHTML = '<p class="admin-empty">No hay imágenes en este periodo. Sube la primera arriba.</p>';
				return;
			}

			slidesList.innerHTML = slides
				.map(
					(slide, index) => `
					<article class="admin-item" data-sortable-item data-id="${slide.id}" draggable="true">
						<div class="admin-item__head">
							<span class="admin-item__handle" title="Arrastrar para reordenar">⋮⋮</span>
							<span class="admin-item__position">${index + 1}</span>
							<span class="admin-item__title">${escapeHtml(slide.alt || 'Sin descripción')}</span>
							<button class="admin-btn admin-btn--danger admin-btn--sm" type="button" data-action="delete">Eliminar</button>
						</div>
						<div class="admin-item__body">
							<div class="admin-item__media">
								<img class="admin-item__preview" src="${escapeHtml(slide.src)}" alt="${escapeHtml(slide.alt)}" />
								<div class="admin-item__fields">
									<div class="admin-field">
										<label>Descripción</label>
										<input data-field="alt" value="${escapeHtml(slide.alt)}" />
									</div>
									<div class="admin-field">
										<label>Archivo</label>
										<input data-field="src" value="${escapeHtml(slide.src)}" readonly />
									</div>
								</div>
							</div>
						</div>
					</article>
				`,
				)
				.join('');

			ensureSortable();
			updatePositionNumbers(slidesList);
		}

		function fillPeriodFields() {
			viewMode.value = schedule.viewMode;
			weekFields.classList.toggle('hidden', schedule.viewMode !== 'week');
			dayFields.classList.toggle('hidden', schedule.viewMode !== 'day');

			weekSelect.innerHTML = schedule.weeks
				.map((week) => `<option value="${week.id}">${week.label}</option>`)
				.join('');
			weekSelect.value = schedule.activeWeekId;

			daySelect.innerHTML = schedule.days
				.map((day) => `<option value="${day.date}">${day.label} (${day.date})</option>`)
				.join('');
			daySelect.value = schedule.activeDate;

			const week = schedule.weeks.find((item) => item.id === schedule.activeWeekId);
			if (week) {
				(document.getElementById('week-label') as HTMLInputElement).value = week.label;
				(document.getElementById('week-start') as HTMLInputElement).value = week.startDate;
				(document.getElementById('week-end') as HTMLInputElement).value = week.endDate;
			}

			const day = schedule.days.find((item) => item.date === schedule.activeDate);
			if (day) {
				(document.getElementById('day-label') as HTMLInputElement).value = day.label;
				(document.getElementById('day-date') as HTMLInputElement).value = day.date;
			}

			renderSlides();
		}

		async function loadSchedule() {
			const response = await fetch('/api/admin/schedule');
			schedule = await response.json();
			fillPeriodFields();
		}

		function syncPeriodFromFields() {
			if (schedule.viewMode === 'week') {
				const week = schedule.weeks.find((item) => item.id === schedule.activeWeekId);
				if (!week) return;
				week.label = (document.getElementById('week-label') as HTMLInputElement).value;
				week.startDate = (document.getElementById('week-start') as HTMLInputElement).value;
				week.endDate = (document.getElementById('week-end') as HTMLInputElement).value;
				return;
			}

			const day = schedule.days.find((item) => item.date === schedule.activeDate);
			if (!day) return;
			day.label = (document.getElementById('day-label') as HTMLInputElement).value;
			day.date = (document.getElementById('day-date') as HTMLInputElement).value;
		}

		viewMode.addEventListener('change', () => {
			schedule.viewMode = viewMode.value as 'week' | 'day';
			fillPeriodFields();
		});

		weekSelect.addEventListener('change', () => {
			syncPeriodFromFields();
			schedule.activeWeekId = weekSelect.value;
			fillPeriodFields();
		});

		daySelect.addEventListener('change', () => {
			syncPeriodFromFields();
			schedule.activeDate = daySelect.value;
			fillPeriodFields();
		});

		document.getElementById('add-period-btn')?.addEventListener('click', () => {
			if (schedule.viewMode === 'week') {
				const id = `week-${Date.now().toString(36)}`;
				schedule.weeks.push({
					id,
					label: 'Nueva semana',
					startDate: new Date().toISOString().slice(0, 10),
					endDate: new Date().toISOString().slice(0, 10),
					slides: [],
				});
				schedule.activeWeekId = id;
			} else {
				const date = new Date().toISOString().slice(0, 10);
				schedule.days.push({ date, label: 'Nuevo día', slides: [] });
				schedule.activeDate = date;
			}
			fillPeriodFields();
		});

		slidesList.addEventListener('click', (event) => {
			const target = event.target as HTMLElement;
			if (target.getAttribute('data-action') !== 'delete') return;

			const item = target.closest('[data-sortable-item]') as HTMLElement;
			const id = item?.getAttribute('data-id');
			const slides = currentSlides();
			const index = slides.findIndex((slide) => slide.id === id);
			if (index < 0) return;

			slides.splice(index, 1);
			slides.forEach((slide, order) => {
				slide.order = order + 1;
			});
			renderSlides();
		});

		document.getElementById('upload-form')?.addEventListener('submit', async (event) => {
			event.preventDefault();
			const fileInput = document.getElementById('slide-file') as HTMLInputElement;
			const altInput = document.getElementById('slide-alt') as HTMLInputElement;
			const file = fileInput.files?.[0];
			if (!file) return;

			setStatus('Subiendo imagen...');
			const formData = new FormData();
			formData.append('file', file);
			formData.append('folder', 'slides');

			const upload = await fetch('/api/admin/upload', { method: 'POST', body: formData });
			const uploaded = await upload.json();
			if (!upload.ok) {
				setStatus(uploaded.error ?? 'Error al subir', 'error');
				return;
			}

			currentSlides().push({
				id: `slide-${Date.now().toString(36)}`,
				src: uploaded.src,
				alt: altInput.value || file.name,
				order: currentSlides().length + 1,
			});

			fileInput.value = '';
			altInput.value = '';
			renderSlides();
			setStatus('Imagen agregada. Recuerda guardar cambios.', 'success');
		});

		document.getElementById('save-btn')?.addEventListener('click', async () => {
			syncPeriodFromFields();
			syncSlidesFromDom();

			const response = await fetch('/api/admin/schedule', {
				method: 'PUT',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(schedule),
			});

			if (!response.ok) {
				setStatus('No se pudo guardar', 'error');
				return;
			}

			setStatus('Cambios guardados correctamente', 'success');
			await loadSchedule();
		});

		loadSchedule();
	</script>
</AdminLayout>
