<audio
	class="agenda-music"
	data-agenda-audio
	preload="auto"
	playsinline
	aria-hidden="true"
></audio>

<script>
	import {
		fetchMusica,
		getApiBase,
		getPollIntervalMs,
		tracksSignature,
		type PublicMusica,
		type PublicTrack,
	} from '../lib/agendaClient';
	import {
		bindMediaUnlock,
		playAudioDirect,
		unbindMediaUnlock,
		waitForAudioReady,
	} from '../lib/kioskMedia';

	let pollTimer: ReturnType<typeof setInterval> | null = null;
	let playRetryTimer: ReturnType<typeof setInterval> | null = null;
	let tracks: PublicTrack[] = [];
	let trackIndex = 0;
	let contentSignature = '';
	let unlockBound = false;
	let loadingTrackUrl = '';

	function getAudio(): HTMLAudioElement | null {
		return document.querySelector<HTMLAudioElement>('[data-agenda-audio]');
	}

	function sortTracks(list: PublicTrack[]): PublicTrack[] {
		return [...list].sort((a, b) => a.orden - b.orden);
	}

	async function setTrackSource(audio: HTMLAudioElement, url: string): Promise<boolean> {
		if (audio.dataset.trackUrl === url && audio.readyState >= HTMLMediaElement.HAVE_FUTURE_DATA) {
			return true;
		}

		audio.dataset.trackUrl = url;
		audio.src = url;
		audio.load();
		loadingTrackUrl = url;
		const ready = await waitForAudioReady(audio);
		if (loadingTrackUrl !== url) return false;
		return ready;
	}

	function ensureUnlockListener() {
		if (unlockBound) return;
		unlockBound = true;
		bindMediaUnlock(() => {
			void playCurrent();
		});
	}

	async function playCurrent(): Promise<void> {
		const audio = getAudio();
		if (!audio || tracks.length === 0) return;

		const track = tracks[trackIndex];
		const loaded = await setTrackSource(audio, track.url);
		if (!loaded) {
			ensureUnlockListener();
			return;
		}

		const ok = await playAudioDirect(audio);
		if (ok) {
			unbindMediaUnlock();
			unlockBound = false;
			return;
		}

		ensureUnlockListener();
	}

	function applyPlaylist(data: PublicMusica) {
		const signature = tracksSignature(data);
		const samePlaylist = signature === contentSignature;
		contentSignature = signature;

		const audio = getAudio();
		if (!audio) return;

		if (!data.playlistEnabled || !data.tracks?.length) {
			tracks = [];
			trackIndex = 0;
			loadingTrackUrl = '';
			delete audio.dataset.trackUrl;
			audio.pause();
			audio.removeAttribute('src');
			audio.load();
			unbindMediaUnlock();
			unlockBound = false;
			return;
		}

		tracks = sortTracks(data.tracks);
		if (!samePlaylist) trackIndex = 0;

		void playCurrent();
	}

	async function refreshMusica() {
		try {
			const data = await fetchMusica(getApiBase());
			applyPlaylist(data);
		} catch {
			const audio = getAudio();
			if (audio) {
				loadingTrackUrl = '';
				delete audio.dataset.trackUrl;
				audio.pause();
				audio.removeAttribute('src');
				audio.load();
			}
			tracks = [];
			contentSignature = '';
			unbindMediaUnlock();
			unlockBound = false;
		}
	}

	function bindAudioEvents() {
		const audio = getAudio();
		if (!audio || audio.dataset.bound === 'true') return;
		audio.dataset.bound = 'true';

		audio.addEventListener('ended', () => {
			if (tracks.length === 0) return;
			trackIndex = (trackIndex + 1) % tracks.length;
			void playCurrent();
		});

		audio.addEventListener('error', () => {
			if (tracks.length <= 1) {
				ensureUnlockListener();
				return;
			}
			trackIndex = (trackIndex + 1) % tracks.length;
			void playCurrent();
		});
	}

	function startPlayRetry() {
		if (playRetryTimer) clearInterval(playRetryTimer);
		playRetryTimer = setInterval(() => {
			const audio = getAudio();
			if (!audio || tracks.length === 0) return;
			if (audio.paused && !audio.ended) void playCurrent();
		}, 4000);
	}

	function startPolling() {
		if (pollTimer) clearInterval(pollTimer);
		pollTimer = setInterval(() => {
			void refreshMusica();
		}, getPollIntervalMs());
	}

	function bootstrap() {
		bindAudioEvents();
		void refreshMusica();
		startPolling();
		startPlayRetry();
	}

	bootstrap();

	document.addEventListener('astro:page-load', bootstrap);

	document.addEventListener('astro:before-preparation', () => {
		if (pollTimer) clearInterval(pollTimer);
		if (playRetryTimer) clearInterval(playRetryTimer);
		pollTimer = null;
		playRetryTimer = null;
		unbindMediaUnlock();
		unlockBound = false;
		getAudio()?.pause();
	});
</script>

<style>
	.agenda-music {
		position: absolute;
		width: 0;
		height: 0;
		opacity: 0;
		pointer-events: none;
	}
</style>
