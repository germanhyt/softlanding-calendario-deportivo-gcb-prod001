---
import { FALLBACK_SLIDES } from '../lib/fallbackSlides';
---

<section class="carousel" aria-label="Agenda deportiva semanal">
	<button
		type="button"
		class="carousel-mode-toggle"
		aria-label="Cambiar entre modo kiosk y modo celular"
		aria-pressed="false"
	>
		<span class="carousel-mode-toggle__track">
			<span class="carousel-mode-toggle__thumb"></span>
		</span>
	</button>

	<div class="swiper sports-swiper">
		<div class="swiper-wrapper" data-agenda-wrapper>
			{
				FALLBACK_SLIDES.map((slide, index) => (
					<div class="swiper-slide">
						<img
							src={slide.src}
							alt={slide.alt}
							loading={index === 0 ? 'eager' : 'lazy'}
						/>
					</div>
				))
			}
		</div>

		<button type="button" class="swiper-button-prev" aria-label="Slide anterior"></button>
		<button type="button" class="swiper-button-next" aria-label="Slide siguiente"></button>
		<div class="swiper-pagination"></div>
	</div>

	<p class="carousel-hint" aria-hidden="true">
		<span class="carousel-hint__chevrons">›››</span>
		Desliza o usa las flechas
	</p>
</section>

<script>
	import Swiper from 'swiper';
	import { Navigation, Pagination, EffectCreative, Keyboard, Mousewheel, A11y, Autoplay } from 'swiper/modules';
	import 'swiper/css';
	import 'swiper/css/navigation';
	import 'swiper/css/pagination';
	import 'swiper/css/effect-creative';

	import {
		fetchProgramacion,
		getApiBase,
		getPollIntervalMs,
		slidesSignature,
		type PublicSlide,
	} from '../lib/agendaClient';
	import { FALLBACK_SLIDES, type CarouselSlide } from '../lib/fallbackSlides';

	const DISPLAY_MODE_KEY = 'catelera-display-mode';
	type DisplayMode = 'kiosk' | 'normal';

	let swiperInstance: Swiper | null = null;
	let slidesContentSignature = '';
	let pollTimer: ReturnType<typeof setInterval> | null = null;

	function escapeAttr(value: string): string {
		return value
			.replace(/&/g, '&amp;')
			.replace(/"/g, '&quot;')
			.replace(/</g, '&lt;')
			.replace(/>/g, '&gt;');
	}

	function detectKiosk(): boolean {
		const w = window.innerWidth;
		const h = window.innerHeight;
		const screenH = window.screen.height;
		const screenW = window.screen.width;
		const isPortrait = h > w || screenH > screenW;

		return (
			h >= 900 ||
			(w >= 600 && isPortrait) ||
			(Math.max(screenH, screenW) >= 1280 && isPortrait)
		);
	}

	function getDisplayMode(): DisplayMode {
		const saved = localStorage.getItem(DISPLAY_MODE_KEY);
		if (saved === 'kiosk' || saved === 'normal') return saved;
		return detectKiosk() ? 'kiosk' : 'normal';
	}

	function applyDisplayMode(mode = getDisplayMode()) {
		const carousel = document.querySelector<HTMLElement>('.carousel');
		const toggle = document.querySelector<HTMLButtonElement>('.carousel-mode-toggle');
		if (!carousel) return;

		const isKiosk = mode === 'kiosk';
		carousel.classList.toggle('carousel--kiosk', isKiosk);
		toggle?.setAttribute('aria-pressed', String(isKiosk));
	}

	function initDisplayModeToggle() {
		const toggle = document.querySelector<HTMLButtonElement>('.carousel-mode-toggle');
		if (!toggle || toggle.dataset.bound === 'true') return;

		toggle.dataset.bound = 'true';
		applyDisplayMode();

		toggle.addEventListener('click', () => {
			const nextMode: DisplayMode =
				toggle.getAttribute('aria-pressed') === 'true' ? 'normal' : 'kiosk';
			localStorage.setItem(DISPLAY_MODE_KEY, nextMode);
			applyDisplayMode(nextMode);
		});
	}

	function destroySwiper() {
		if (swiperInstance) {
			swiperInstance.destroy(true, true);
			swiperInstance = null;
		}
		const el = document.querySelector<HTMLElement>('.sports-swiper');
		if (el) delete el.dataset.initialized;
	}

	function mountSwiper() {
		const el = document.querySelector<HTMLElement>('.sports-swiper');
		if (!el) return;

		destroySwiper();
		el.dataset.initialized = 'true';

		swiperInstance = new Swiper(el, {
			modules: [Navigation, Pagination, EffectCreative, Keyboard, Mousewheel, A11y, Autoplay],
			effect: 'creative',
			creativeEffect: {
				prev: {
					shadow: true,
					translate: ['-110%', 0, -400],
					rotate: [0, 0, -8],
					opacity: 0,
				},
				next: {
					shadow: true,
					translate: ['110%', 0, -400],
					rotate: [0, 0, 8],
					opacity: 0,
				},
			},
			loop: true,
			speed: 650,
			autoplay: {
				delay: 10000,
				pauseOnMouseEnter: true,
				disableOnInteraction: false,
			},
			grabCursor: true,
			keyboard: { enabled: true, onlyInViewport: true },
			mousewheel: {
				forceToAxis: true,
				sensitivity: 1,
				thresholdDelta: 20,
			},
			navigation: {
				nextEl: '.swiper-button-next',
				prevEl: '.swiper-button-prev',
			},
			pagination: {
				el: '.swiper-pagination',
				clickable: true,
				dynamicBullets: true,
			},
			a11y: {
				prevSlideMessage: 'Slide anterior',
				nextSlideMessage: 'Slide siguiente',
				paginationBulletMessage: 'Ir al slide {{index}}',
			},
		});

	}

	function renderSlides(slides: CarouselSlide[]) {
		const wrapper = document.querySelector<HTMLElement>('[data-agenda-wrapper]');
		if (!wrapper) return;

		wrapper.innerHTML = slides
			.map(
				(slide, index) => `
			<div class="swiper-slide">
				<img src="${escapeAttr(slide.src)}" alt="${escapeAttr(slide.alt)}" loading="${index === 0 ? 'eager' : 'lazy'}" />
			</div>`
			)
			.join('');
	}

	function mapApiSlides(slides: PublicSlide[]): CarouselSlide[] {
		return [...slides]
			.sort((a, b) => a.orden - b.orden)
			.map((slide) => ({ src: slide.url, alt: slide.alt || `Slide ${slide.orden}` }));
	}

	function resolveSlides(apiSlides: PublicSlide[]): CarouselSlide[] {
		const mapped = mapApiSlides(apiSlides);
		return mapped.length > 0 ? mapped : FALLBACK_SLIDES;
	}

	function fallbackSignature(): string {
		return `fallback:${FALLBACK_SLIDES.map((s) => s.src).join('|')}`;
	}

	function applySlides(slides: CarouselSlide[], signature: string) {
		if (signature === slidesContentSignature && swiperInstance) return;
		slidesContentSignature = signature;
		renderSlides(slides);
		mountSwiper();
		applyDisplayMode();
	}

	async function refreshFromApi() {
		try {
			const data = await fetchProgramacion(getApiBase());
			const slides = resolveSlides(data.slides ?? []);
			const signature =
				data.slides?.length > 0 ? slidesSignature(data.slides) : fallbackSignature();
			applySlides(slides, signature);
		} catch {
			const signature = fallbackSignature();
			if (slidesContentSignature !== signature) {
				applySlides(FALLBACK_SLIDES, signature);
			}
		}
	}

	function startPolling() {
		if (pollTimer) clearInterval(pollTimer);
		pollTimer = setInterval(() => {
			void refreshFromApi();
		}, getPollIntervalMs());
	}

	function bootstrap() {
		if (pollTimer) {
			clearInterval(pollTimer);
			pollTimer = null;
		}
		initDisplayModeToggle();
		slidesContentSignature = fallbackSignature();
		if (!swiperInstance) {
			mountSwiper();
		}
		applyDisplayMode();
		void refreshFromApi();
		startPolling();
	}

	bootstrap();

	window.addEventListener('resize', () => {
		if (!localStorage.getItem(DISPLAY_MODE_KEY)) {
			applyDisplayMode();
		}
	});

	document.addEventListener('astro:page-load', () => {
		bootstrap();
	});

	document.addEventListener('astro:before-preparation', () => {
		if (pollTimer) {
			clearInterval(pollTimer);
			pollTimer = null;
		}
		destroySwiper();
	});
</script>

<style>
	.carousel {
		position: relative;
		width: 100vw;
		width: 100dvw;
		height: 100vh;
		height: 100dvh;
		min-height: -webkit-fill-available;
		background: radial-gradient(ellipse at center, #142014 0%, #0a1209 70%);
	}

	.carousel--kiosk {
		background: #0a1209;
	}

	.sports-swiper {
		width: 100%;
		height: 100%;
	}

	.carousel-mode-toggle {
		position: absolute;
		top: calc(0.45rem + env(safe-area-inset-top));
		right: calc(0.45rem + env(safe-area-inset-right));
		z-index: 10;
		padding: 0.4rem;
		border: none;
		background: transparent;
		cursor: pointer;
		opacity: 0.1;
		transition: opacity 0.35s ease;
		-webkit-tap-highlight-color: transparent;
	}

	.carousel-mode-toggle:hover,
	.carousel-mode-toggle:focus-visible,
	.carousel-mode-toggle:active {
		opacity: 0.5;
		outline: none;
	}

	.carousel-mode-toggle__track {
		display: block;
		width: 1.35rem;
		height: 0.75rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.2);
		position: relative;
		transition: background 0.25s ease;
	}

	.carousel-mode-toggle[aria-pressed='true'] .carousel-mode-toggle__track {
		background: rgba(255, 255, 255, 0.35);
	}

	.carousel-mode-toggle__thumb {
		position: absolute;
		top: 1px;
		left: 1px;
		width: calc(0.75rem - 2px);
		height: calc(0.75rem - 2px);
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.45);
		transition:
			transform 0.25s ease,
			background 0.25s ease;
	}

	.carousel-mode-toggle[aria-pressed='true'] .carousel-mode-toggle__thumb {
		transform: translateX(0.6rem);
		background: rgba(255, 255, 255, 0.7);
	}

	.carousel--kiosk .carousel-hint {
		display: none;
	}

	.carousel-hint {
		position: absolute;
		bottom: calc(1.25rem + env(safe-area-inset-bottom));
		left: 50%;
		transform: translateX(-50%);
		margin: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.15rem;
		color: rgba(255, 255, 255, 0.55);
		font-size: 0.7rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		pointer-events: none;
		z-index: 5;
		animation: hint-fade 4s ease forwards;
	}

	.carousel-hint__chevrons {
		display: block;
		font-size: 1rem;
		line-height: 1;
		letter-spacing: -0.15em;
		animation: hint-bounce 1.6s ease-in-out infinite;
	}

	@keyframes hint-fade {
		0%,
		70% {
			opacity: 1;
		}
		100% {
			opacity: 0;
		}
	}

	@keyframes hint-bounce {
		0%,
		100% {
			transform: translateX(0);
		}
		50% {
			transform: translateX(4px);
		}
	}
</style>

<style is:global>
	/* Slides: global para que innerHTML dinámico (API) conserve el mismo layout que el SSR. */
	.sports-swiper .swiper-slide {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom)
			env(safe-area-inset-left);
	}

	.sports-swiper .swiper-slide img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: center;
		user-select: none;
		-webkit-user-drag: none;
		pointer-events: none;
	}

	.carousel:not(.carousel--kiosk) .sports-swiper .swiper-slide img {
		object-fit: contain;
	}

	@media (min-width: 600px) {
		.carousel:not(.carousel--kiosk) .sports-swiper .swiper-slide img {
			max-width: min(100%, 480px);
		}
	}

	.carousel--kiosk .sports-swiper .swiper-slide {
		padding: 0;
	}

	.carousel--kiosk .sports-swiper .swiper-slide img {
		object-fit: cover;
		width: 100%;
		height: 100%;
		max-width: none;
	}

	.sports-swiper .swiper-button-prev,
	.sports-swiper .swiper-button-next {
		color: #fff;
		width: 2rem;
		height: 2rem;
		margin-top: -1rem;
		border-radius: 50%;
		background: rgba(0, 0, 0, 0.2);
		border: none;
		opacity: 0;
		transition:
			opacity 0.3s ease,
			background 0.2s ease,
			transform 0.2s ease;
	}

	.sports-swiper .swiper-button-prev::after,
	.sports-swiper .swiper-button-next::after {
		font-size: 0.85rem;
		font-weight: 600;
	}

	.carousel:hover .sports-swiper .swiper-button-prev,
	.carousel:hover .sports-swiper .swiper-button-next,
	.carousel:focus-within .sports-swiper .swiper-button-prev,
	.carousel:focus-within .sports-swiper .swiper-button-next {
		opacity: 0.45;
	}

	.sports-swiper .swiper-button-prev:hover,
	.sports-swiper .swiper-button-next:hover {
		opacity: 0.9;
		background: rgba(0, 0, 0, 0.35);
	}

	.sports-swiper .swiper-button-prev:active,
	.sports-swiper .swiper-button-next:active {
		transform: scale(0.94);
	}

	.sports-swiper .swiper-button-prev {
		left: 0.5rem;
	}

	.sports-swiper .swiper-button-next {
		right: 0.5rem;
	}

	.sports-swiper .swiper-pagination {
		bottom: calc(0.75rem + env(safe-area-inset-bottom));
		left: 0;
		width: 100%;
	}

	.sports-swiper .swiper-pagination-bullet {
		width: 0.45rem;
		height: 0.45rem;
		background: rgba(255, 255, 255, 0.35);
		opacity: 1;
		transition:
			transform 0.25s ease,
			background 0.25s ease;
	}

	.sports-swiper .swiper-pagination-bullet-active {
		background: #fff;
		transform: scale(1.35);
	}

	.carousel--kiosk .sports-swiper .swiper-pagination {
		bottom: 0.5rem;
	}

	.carousel--kiosk .sports-swiper .swiper-pagination-bullet {
		width: 0.35rem;
		height: 0.35rem;
	}

	@media (hover: none), (pointer: coarse) {
		.sports-swiper .swiper-button-prev,
		.sports-swiper .swiper-button-next {
			display: none;
		}
	}

	@media (min-width: 768px) {
		.sports-swiper .swiper-button-prev {
			left: 0.75rem;
		}

		.sports-swiper .swiper-button-next {
			right: 0.75rem;
		}
	}
</style>
